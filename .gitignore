```gitignore
# =========================
# Python
# =========================
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/
ENV/

# =========================
# Environment variables
# =========================
.env
.env.*
!.env.example

# =========================
# Jupyter
# =========================
.ipynb_checkpoints/

# =========================
# VS Code
# =========================
.vscode/

# =========================
# PyCharm
# =========================
.idea/

# =========================
# Streamlit
# =========================
.streamlit/secrets.toml

# =========================
# Logs
# =========================
*.log
logs/

# =========================
# OS files
# =========================
.DS_Store
Thumbs.db

# =========================
# Build / distribution
# =========================
build/
dist/
*.egg-info/

# =========================
# Testing
# =========================
.pytest_cache/
.coverage
htmlcov/

# =========================
# ChromaDB / Vector DB
# =========================
chroma/
chromadb/
*.sqlite3

# =========================
# Model files
# =========================
models/
*.bin
*.pt
*.pth
*.onnx

# =========================
# Cache
# =========================
.cache/
*.cache

# =========================
# Temporary files
# =========================
tmp/
temp/
*.tmp

# =========================
# Node modules (if frontend exists)
# =========================
node_modules/

# =========================
# Uploads / generated docs
# =========================
uploads/
generated/
```
